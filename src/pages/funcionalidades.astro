---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import ProductShowcase from "../components/ProductShowcase.astro";
import CRMShowcase from "../components/CRMShowcase.astro";
import Differentiators from "../components/Differentiators.astro";
import IntelligenceTeaser from "../components/IntelligenceTeaser.astro";
import AccessForm from "../components/AccessForm.astro";
import Footer from "../components/Footer.astro";
---

<Base
  title="Funcionalidades — ContRadar"
  description="Alertas inteligentes, sistema de seguimiento de equipo, tablero de oportunidades y panel de métricas. Todo lo que necesitas para ganar más contratos públicos en Colombia."
>
  <Nav />
  <main>

    <!-- Page intro -->
    <section class="relative overflow-hidden bg-navy-deep text-white">
      <div class="pointer-events-none absolute inset-0 opacity-[0.04]" aria-hidden="true">
        <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <pattern id="dots-func" width="32" height="32" patternUnits="userSpaceOnUse">
              <circle cx="1.5" cy="1.5" r="1.5" fill="white"/>
            </pattern>
          </defs>
          <rect width="100%" height="100%" fill="url(#dots-func)"/>
        </svg>
      </div>
      <div class="pointer-events-none absolute -top-24 left-1/3 h-80 w-80 rounded-full bg-teal/15 blur-3xl" aria-hidden="true"></div>
      <div class="relative mx-auto max-w-4xl px-5 py-20 text-center sm:px-8">
        <a href="/" class="inline-flex items-center gap-1.5 rounded-full bg-white/10 px-3 py-1.5 text-xs font-medium text-slate-300 ring-1 ring-white/15 transition hover:bg-white/15 mb-6">
          <svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M9.707 14.707a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 1.414L7.414 9H15a1 1 0 110 2H7.414l2.293 2.293a1 1 0 010 1.414z" clip-rule="evenodd"/>
          </svg>
          ContRadar
        </a>
        <h1 class="text-3xl font-extrabold tracking-tight sm:text-4xl lg:text-5xl text-wrap-balance">
          Una plataforma completa.<br/>
          <span class="text-teal">No solo alertas.</span>
        </h1>
        <p class="mt-4 mx-auto max-w-xl text-lg text-slate-300">
          Desde configurar tus búsquedas hasta cerrar el contrato, todo pasa en ContRadar.
          Sin correos perdidos. Sin hojas de Excel. Sin salir a ningún lado.
        </p>
      </div>
    </section>

    <ProductShowcase />
    <CRMShowcase />
    <Differentiators />
    <IntelligenceTeaser />
    <AccessForm />

  </main>
  <Footer />
</Base>
