---
// LegalLayout.astro — layout para páginas legales (/terminos, /politica-de-datos).
// Mismo marco (Base + Nav + Footer) que el resto del sitio, con tipografía de
// documento largo (.legal-prose). Sin CTA ni schema de guías.
import Base from "./Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string; // <title> SEO
  description: string; // meta description
  h1: string; // titular visible
  updated: string; // "Última actualización: …"
}

const { title, description, h1, updated } = Astro.props;
---

<Base title={title} description={description}>
  <Nav />
  <main>
    <!-- Encabezado -->
    <section class="relative overflow-hidden bg-navy-deep text-white">
      <div class="pointer-events-none absolute -top-24 left-1/3 h-80 w-80 rounded-full bg-teal/15 blur-3xl" aria-hidden="true"></div>
      <div class="relative mx-auto max-w-3xl px-5 py-14 sm:px-8">
        <a href="/" class="mb-6 inline-flex items-center gap-1.5 rounded-full bg-white/10 px-3 py-1.5 text-xs font-medium text-slate-300 ring-1 ring-white/15 transition hover:bg-white/15">
          <svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M9.707 14.707a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 1.414L7.414 9H15a1 1 0 110 2H7.414l2.293 2.293a1 1 0 010 1.414z" clip-rule="evenodd"/>
          </svg>
          ContRadar
        </a>
        <h1 class="text-3xl font-extrabold tracking-tight sm:text-4xl text-wrap-balance">{h1}</h1>
        <p class="mt-3 text-sm text-slate-400">{updated}</p>
      </div>
    </section>

    <!-- Contenido -->
    <article class="bg-white">
      <div class="legal-prose mx-auto max-w-3xl px-5 py-12 sm:px-8">
        <slot />
      </div>
    </article>
  </main>
  <Footer />
</Base>

<style is:global>
  .legal-prose h2 {
    margin-top: 2.25rem;
    font-size: 1.35rem;
    font-weight: 800;
    letter-spacing: -0.01em;
    color: #1a2e4a;
  }
  .legal-prose h3 {
    margin-top: 1.5rem;
    font-size: 1.05rem;
    font-weight: 700;
    color: #1a2e4a;
  }
  .legal-prose p {
    margin-top: 1rem;
    line-height: 1.75;
    color: #475569;
  }
  .legal-prose ul {
    margin-top: 1rem;
    padding-left: 1.4rem;
    list-style: disc;
    color: #475569;
    line-height: 1.7;
  }
  .legal-prose li {
    margin-top: 0.35rem;
  }
  .legal-prose a {
    color: #0ea5e9;
    text-decoration: underline;
  }
  .legal-prose strong {
    color: #1a2e4a;
    font-weight: 700;
  }
  .legal-prose .table-wrap {
    margin-top: 1.25rem;
    overflow-x: auto;
  }
  .legal-prose table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }
  .legal-prose th,
  .legal-prose td {
    border: 1px solid #e2e8f0;
    padding: 0.6rem 0.7rem;
    text-align: left;
    vertical-align: top;
    color: #475569;
  }
  .legal-prose th {
    background: #f8fafc;
    font-weight: 700;
    color: #1a2e4a;
  }
</style>
