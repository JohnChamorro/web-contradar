---
// GuideLayout.astro — layout para guías SEO (/guias/*).
// Responde la búsqueda en el primer párrafo, schema Article + Breadcrumb + FAQ opcional.
import Base from "./Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;        // <title> SEO
  description: string;  // meta description
  h1: string;           // titular visible
  slug: string;         // ej. "que-es-el-paa"
  datePublished: string; // "2026-07-07"
  faq?: { q: string; a: string }[];
}

const { title, description, h1, slug, datePublished, faq } = Astro.props;
const url = `https://contradar.com.co/guias/${slug}`;

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: h1,
  description,
  inLanguage: "es-CO",
  datePublished,
  dateModified: datePublished,
  mainEntityOfPage: url,
  author: { "@type": "Organization", name: "ContRadar", url: "https://contradar.com.co" },
  publisher: {
    "@type": "Organization",
    name: "ContRadar",
    logo: { "@type": "ImageObject", url: "https://contradar.com.co/android-chrome-512x512.png" },
  },
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Inicio", item: "https://contradar.com.co/" },
    { "@type": "ListItem", position: 2, name: "Guías", item: "https://contradar.com.co/guias" },
    { "@type": "ListItem", position: 3, name: h1, item: url },
  ],
};

const faqSchema = faq && faq.length
  ? {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: faq.map((f) => ({
        "@type": "Question",
        name: f.q,
        acceptedAnswer: { "@type": "Answer", text: f.a },
      })),
    }
  : null;
---

<Base title={title} description={description}>
  <Nav />
  <main>

    <!-- Encabezado -->
    <section class="relative overflow-hidden bg-navy-deep text-white">
      <div class="pointer-events-none absolute -top-24 left-1/3 h-80 w-80 rounded-full bg-teal/15 blur-3xl" aria-hidden="true"></div>
      <div class="relative mx-auto max-w-3xl px-5 py-14 sm:px-8">
        <nav class="text-xs text-slate-400" aria-label="breadcrumb">
          <a href="/" class="hover:text-white transition">Inicio</a>
          <span class="mx-1.5">/</span>
          <a href="/guias" class="hover:text-white transition">Guías</a>
        </nav>
        <h1 class="mt-4 text-3xl font-extrabold tracking-tight sm:text-4xl text-wrap-balance">{h1}</h1>
        <p class="mt-3 text-lg text-slate-300">{description}</p>
      </div>
    </section>

    <!-- Contenido -->
    <article class="bg-white">
      <div class="guide-prose mx-auto max-w-3xl px-5 py-12 sm:px-8">
        <slot />
      </div>
    </article>

    <!-- CTA final -->
    <section class="bg-slate-50">
      <div class="mx-auto max-w-3xl px-5 py-12 text-center sm:px-8">
        <h2 class="text-2xl font-extrabold tracking-tight text-navy">Deja de buscar licitaciones. Ellas te encuentran.</h2>
        <p class="mt-3 mx-auto max-w-xl text-slate-600">
          ContRadar monitorea SECOP I y II, filtra lo que encaja con tu empresa y te avisa por correo.
          Tu equipo gestiona todo en un solo lugar.
        </p>
        <div class="mt-6 flex flex-wrap justify-center gap-3">
          <a href="/#solicitar" class="rounded-xl bg-navy px-6 py-3 text-sm font-bold text-white shadow-md transition hover:bg-navy-deep">
            Solicitar acceso →
          </a>
          <a href="/precios" class="rounded-xl border border-navy/30 px-6 py-3 text-sm font-semibold text-navy transition hover:bg-navy hover:text-white">
            Ver planes y precios
          </a>
        </div>
      </div>
    </section>

  </main>
  <Footer />

  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
</Base>

<style is:global>
  .guide-prose h2 {
    margin-top: 2.25rem;
    font-size: 1.5rem;
    font-weight: 800;
    letter-spacing: -0.015em;
    color: #1a2e4a;
  }
  .guide-prose h3 {
    margin-top: 1.75rem;
    font-size: 1.125rem;
    font-weight: 700;
    color: #1a2e4a;
  }
  .guide-prose p {
    margin-top: 1rem;
    line-height: 1.75;
    color: #475569;
  }
  .guide-prose ul, .guide-prose ol {
    margin-top: 1rem;
    padding-left: 1.4rem;
    color: #475569;
    line-height: 1.7;
  }
  .guide-prose ul { list-style: disc; }
  .guide-prose ol { list-style: decimal; }
  .guide-prose li { margin-top: 0.4rem; }
  .guide-prose li::marker { color: #14b8a6; }
  .guide-prose strong { color: #1a2e4a; }
  .guide-prose a { color: #0284c7; font-weight: 600; }
  .guide-prose a:hover { text-decoration: underline; }
  .guide-prose .lead {
    margin-top: 0;
    font-size: 1.125rem;
    color: #334155;
  }
  .guide-prose .callout {
    margin-top: 1.5rem;
    border-radius: 1rem;
    background: #f0fdfa;
    border: 1px solid rgba(20, 184, 166, 0.25);
    padding: 1.1rem 1.3rem;
  }
  .guide-prose .callout p { margin-top: 0; }
  .guide-prose table {
    margin-top: 1.5rem;
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }
  .guide-prose th {
    text-align: left;
    padding: 0.6rem 0.8rem;
    background: #f8fafc;
    color: #1a2e4a;
    font-weight: 700;
    border-bottom: 2px solid #e2e8f0;
  }
  .guide-prose td {
    padding: 0.6rem 0.8rem;
    border-bottom: 1px solid #f1f5f9;
    color: #475569;
    vertical-align: top;
  }
</style>
