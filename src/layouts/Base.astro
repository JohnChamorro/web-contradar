---
import "../styles/global.css";
import { SITE_NAME, SITE_DESCRIPTION } from "../consts";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `ContRadar — App de licitaciones y alertas de SECOP I y II en Colombia`,
  description = SITE_DESCRIPTION,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL("/og-image.png", Astro.site);
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#0f172a" />
    <link rel="canonical" href={canonical} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="licitaciones, licitaciones Colombia, app de licitaciones, app licitaciones Colombia, licitaciones automáticas, alertas de licitaciones, alertas de licitaciones automáticas, SECOP, SECOP I, SECOP II, monitoreo SECOP, buscador de licitaciones, seguimiento de licitaciones, CRM de licitaciones, contratación pública Colombia, cómo licitar con el Estado, ayuda para licitar, oportunidades de contratación, análisis de competencia en licitaciones, Plan Anual de Adquisiciones, PAA, concursos públicos Colombia" />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="eulertech" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="es_CO" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="ContRadar — monitoreo y seguimiento de licitaciones SECOP I y II" />
    <meta property="og:site_name" content="ContRadar" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Structured data -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "ContRadar",
      "description": "Plataforma de alertas y seguimiento de licitaciones de SECOP I y SECOP II en Colombia. Incluye CRM de licitaciones, pipeline Kanban y asignación de equipo.",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "es-CO",
      "url": "https://contradar.com.co",
      "offers": {
        "@type": "AggregateOffer",
        "priceCurrency": "COP",
        "lowPrice": "152000",
        "highPrice": "990000",
        "offerCount": "3"
      },
      "featureList": [
        "Monitoreo SECOP I y SECOP II",
        "Alertas de licitaciones por correo",
        "CRM de licitaciones con pipeline Kanban",
        "Seguimiento de oportunidades",
        "Asignación de responsables",
        "Análisis de competencia 2023-2025",
        "Buscador PAA (Plan Anual de Adquisiciones)",
        "Dashboard de métricas"
      ]
    }
    </script>

    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "ContRadar",
      "legalName": "eulertech",
      "url": "https://contradar.com.co",
      "logo": "https://contradar.com.co/android-chrome-512x512.png",
      "image": "https://contradar.com.co/og-image.png",
      "email": "soporte@contradar.com.co",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Popayán",
        "addressRegion": "Cauca",
        "postalCode": "190002",
        "addressCountry": "CO"
      },
      "sameAs": ["https://app.contradar.com.co"]
    }
    </script>

    <!-- Manrope -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-white font-sans text-slate-800 antialiased">
    <slot />
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add("revealed");
              observer.unobserve(e.target);
            }
          });
        },
        { threshold: 0.12 }
      );
      document.querySelectorAll("[data-reveal]").forEach((el) => observer.observe(el));

      // Scroll confiable al formulario (#solicitar): las imágenes lazy cargan
      // después del salto al ancla y empujan el layout, dejando al usuario una
      // sección arriba. Se re-ancla hasta que la posición se estabiliza.
      const scrollToForm = (smooth: boolean) => {
        const el = document.getElementById("solicitar");
        if (!el) return;
        el.scrollIntoView({ behavior: smooth ? "smooth" : "auto", block: "start" });
        let attempts = 0;
        const settle = window.setInterval(() => {
          attempts++;
          const top = el.getBoundingClientRect().top;
          if (Math.abs(top - 64) > 8) {
            el.scrollIntoView({ behavior: "auto", block: "start" });
          } else if (attempts > 3) {
            window.clearInterval(settle);
          }
          if (attempts >= 12) window.clearInterval(settle);
        }, 250);
      };

      document.addEventListener("click", (e) => {
        const a = (e.target as Element | null)?.closest?.('a[href="#solicitar"]');
        if (!a) return;
        e.preventDefault();
        history.pushState(null, "", "#solicitar");
        scrollToForm(true);
      });

      if (window.location.hash === "#solicitar") {
        window.addEventListener("load", () => scrollToForm(false));
      }
    </script>
  </body>
</html>
