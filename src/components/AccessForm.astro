---
import { SECTORS_FOR_FORM } from "../data/content";
import { CONTACT_EMAIL } from "../consts";
---

<section id="solicitar" class="scroll-mt-16 bg-navy-deep">
  <div class="mx-auto grid max-w-6xl items-center gap-12 px-5 py-20 sm:px-8 lg:grid-cols-2">
    <div class="text-white">
      <span class="rounded-full bg-teal/15 px-3 py-1 text-xs font-bold uppercase tracking-wide text-teal ring-1 ring-teal/30">
        10 días gratis · Plan completo · Sin tarjeta
      </span>
      <h2 class="mt-4 text-3xl font-bold tracking-tight sm:text-4xl">Activa tu prueba gratis</h2>
      <p class="mt-4 max-w-md text-lg text-slate-300">
        Cuéntanos a qué se dedica tu empresa y te activamos la prueba: <strong class="text-white">10
        días con el plan completo</strong>. Un asistente guiado configura tus búsquedas en 2 minutos y
        ves tus primeras licitaciones de una vez. Sin tarjeta y sin permanencia.
      </p>
      <p class="mt-6 text-sm text-slate-400">
        ¿Prefieres escribirnos directo?
        <a href={`mailto:${CONTACT_EMAIL}`} class="font-semibold text-sky hover:underline">
          {CONTACT_EMAIL}
        </a>
      </p>
    </div>

    <div class="rounded-2xl bg-white p-7 shadow-2xl ring-1 ring-black/5">
      <form id="access-form" class="space-y-4">
        <div>
          <label for="f-name" class="mb-1 block text-sm font-medium text-slate-700">Nombre</label>
          <input id="f-name" name="name" type="text"
            class="w-full rounded-lg border border-slate-200 px-3 py-2.5 text-sm outline-none focus:border-sky focus:ring-2 focus:ring-sky/30" />
        </div>
        <div>
          <label for="f-company" class="mb-1 block text-sm font-medium text-slate-700">Empresa</label>
          <input id="f-company" name="company" type="text"
            class="w-full rounded-lg border border-slate-200 px-3 py-2.5 text-sm outline-none focus:border-sky focus:ring-2 focus:ring-sky/30" />
        </div>
        <div>
          <label for="f-email" class="mb-1 block text-sm font-medium text-slate-700">Correo <span class="text-sky">*</span></label>
          <input id="f-email" name="email" type="email" required
            class="w-full rounded-lg border border-slate-200 px-3 py-2.5 text-sm outline-none focus:border-sky focus:ring-2 focus:ring-sky/30" />
        </div>
        <div>
          <label for="f-whatsapp" class="mb-1 block text-sm font-medium text-slate-700">WhatsApp</label>
          <input id="f-whatsapp" name="whatsapp" type="tel" inputmode="tel" placeholder="300 000 0000"
            class="w-full rounded-lg border border-slate-200 px-3 py-2.5 text-sm outline-none focus:border-sky focus:ring-2 focus:ring-sky/30" />
        </div>
        <div>
          <label for="f-sector" class="mb-1 block text-sm font-medium text-slate-700">Sector</label>
          <select id="f-sector" name="sector"
            class="w-full rounded-lg border border-slate-200 bg-white px-3 py-2.5 text-sm outline-none focus:border-sky focus:ring-2 focus:ring-sky/30">
            <option value="">Selecciona tu sector…</option>
            {SECTORS_FOR_FORM.map((s) => <option value={s}>{s}</option>)}
          </select>
        </div>
        <div>
          <label for="f-message" class="mb-1 block text-sm font-medium text-slate-700">Descripción de tu proyecto</label>
          <textarea id="f-message" name="message" rows="3"
            placeholder="Cuéntanos qué buscas monitorear, tu ticket, territorio…"
            class="w-full resize-y rounded-lg border border-slate-200 px-3 py-2.5 text-sm outline-none focus:border-sky focus:ring-2 focus:ring-sky/30"></textarea>
        </div>

        <button id="f-submit" type="submit"
          class="w-full rounded-xl bg-navy px-5 py-3 text-sm font-semibold text-white transition hover:bg-navy-deep disabled:opacity-60">
          Empezar mi prueba gratis →
        </button>

        <p class="text-center text-xs text-slate-400">
          Sin tarjeta de crédito. Te contactamos para activar tu cuenta; la configuración es un asistente guiado de 2 minutos.
        </p>

        <p id="f-msg" class="hidden text-sm" role="status"></p>
      </form>
    </div>
  </div>
</section>

<!-- Popup de resultado: visible esté donde esté el scroll (el mensaje inline
     queda fuera de pantalla si el usuario está abajo). -->
<div id="f-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-navy/70 p-4">
  <div class="w-full max-w-sm rounded-2xl bg-white p-6 text-center shadow-2xl">
    <div id="f-modal-emoji" class="text-4xl">🎉</div>
    <h3 id="f-modal-title" class="mt-3 text-lg font-bold text-navy"></h3>
    <p id="f-modal-body" class="mt-2 text-sm text-slate-600"></p>
    <button id="f-modal-close" type="button"
      class="mt-5 w-full rounded-xl bg-navy px-5 py-3 text-sm font-semibold text-white transition hover:bg-navy-deep">
      Entendido
    </button>
  </div>
</div>

<script>
  const form   = document.getElementById("access-form") as HTMLFormElement | null;
  const btn    = document.getElementById("f-submit") as HTMLButtonElement | null;
  const msg    = document.getElementById("f-msg");
  const modal  = document.getElementById("f-modal");
  let sent = false; // tras un envío OK el botón queda deshabilitado hasta que cambien algo

  function setMsg(text: string, ok: boolean) {
    if (!msg) return;
    msg.textContent = text;
    msg.className = `text-sm ${ok ? "text-teal" : "text-red-600"}`;
    msg.classList.remove("hidden");
  }

  function showModal(ok: boolean, title: string, body: string) {
    if (!modal) return;
    (document.getElementById("f-modal-emoji") as HTMLElement).textContent = ok ? "🎉" : "😕";
    (document.getElementById("f-modal-title") as HTMLElement).textContent = title;
    (document.getElementById("f-modal-body") as HTMLElement).textContent = body;
    modal.classList.remove("hidden");
    modal.classList.add("flex");
  }
  function hideModal() {
    modal?.classList.add("hidden");
    modal?.classList.remove("flex");
  }
  document.getElementById("f-modal-close")?.addEventListener("click", hideModal);
  modal?.addEventListener("click", (e) => { if (e.target === modal) hideModal(); });

  // Si el usuario edita cualquier campo después de un envío OK, se rehabilita
  // (puede registrar a otra persona/correo).
  form?.addEventListener("input", () => {
    if (sent && btn) {
      sent = false;
      btn.disabled = false;
      btn.textContent = "Empezar mi prueba gratis →";
    }
  });

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!btn || sent) return;
    btn.disabled = true;
    btn.textContent = "Enviando…";
    try {
      const payload = Object.fromEntries(new FormData(form).entries());
      const res = await fetch("/api/contact", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
      });
      const data = await res.json();
      if (!res.ok || !data.ok) throw new Error(data.error ?? "Error");
      sent = true;
      btn.textContent = "✅ Solicitud enviada";
      setMsg("¡Solicitud recibida! En breve creamos tu prueba y te avisamos a tu correo.", true);
      showModal(true, "¡Solicitud recibida!",
        "En breve creamos tu prueba de 10 días y te avisamos a tu correo.");
    } catch {
      btn.disabled = false;
      btn.textContent = "Empezar mi prueba gratis →";
      setMsg("No se pudo enviar. Escríbenos directamente a soporte@contradar.com.co", false);
      showModal(false, "No pudimos enviar tu solicitud",
        "Intenta de nuevo en un momento o escríbenos a soporte@contradar.com.co.");
    }
  });
</script>
