---
import Logo from "./Logo.astro";
import { CONTACT_EMAIL, LOGIN_URL } from "../consts";
const year = new Date().getFullYear();
---

<footer class="border-t border-slate-200 bg-white">
  <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-4 px-5 py-8 text-sm text-slate-500 sm:flex-row sm:px-8">
    <div class="flex items-center gap-2">
      <span class="text-lg text-navy"><Logo /></span>
      <span class="text-slate-400">·</span>
      <span>Monitoreo inteligente de licitaciones · Popayán, Colombia · Un producto de eulertech</span>
    </div>
    <div class="flex items-center gap-5">
      <a href="/nosotros" class="transition hover:text-navy">Nosotros</a>
      <a href={LOGIN_URL} class="transition hover:text-navy">Ingresar</a>
      <a href={`mailto:${CONTACT_EMAIL}`} class="transition hover:text-navy">{CONTACT_EMAIL}</a>
      <span>© {year} ContRadar</span>
    </div>
  </div>
</footer>
