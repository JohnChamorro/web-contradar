<section id="diferencias" class="relative overflow-hidden bg-navy text-white">
  <!-- Grid overlay -->
  <div class="pointer-events-none absolute inset-0 opacity-[0.04]" aria-hidden="true">
    <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="grid-diff" width="40" height="40" patternUnits="userSpaceOnUse">
          <path d="M 40 0 L 0 0 0 40" fill="none" stroke="white" stroke-width="0.5"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#grid-diff)"/>
    </svg>
  </div>

  <div class="relative mx-auto max-w-6xl px-5 py-20 sm:px-8">
    <div class="mx-auto max-w-2xl text-center" data-reveal>
      <span class="rounded-full bg-sky/20 px-3 py-1 text-xs font-semibold text-sky ring-1 ring-sky/30">
        Ventaja competitiva
      </span>
      <h2 class="mt-4 text-3xl font-bold tracking-tight sm:text-4xl">
        Más que alertas: inteligencia para licitaciones
      </h2>
      <p class="mt-3 text-lg text-slate-300">
        Otras herramientas mandan listas. ContRadar te da ventaja real sobre la competencia.
      </p>
    </div>

    <!-- Big two: RT + CRM -->
    <div class="mt-12 grid gap-5 lg:grid-cols-2">

      <!-- Real-time — big card -->
      <div class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-sky/20 to-sky/5 p-8 ring-2 ring-sky/40 card-hover" data-reveal data-delay="100">
        <!-- Background radar circles -->
        <div class="pointer-events-none absolute -right-10 -top-10 h-48 w-48 rounded-full border border-sky/20" aria-hidden="true"></div>
        <div class="pointer-events-none absolute -right-4 -top-4 h-32 w-32 rounded-full border border-sky/20" aria-hidden="true"></div>

        <div class="relative">
          <div class="flex items-center gap-3">
            <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-sky/20 text-sky">
              <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
              </svg>
            </div>
            <span class="rounded-full bg-sky/30 px-2.5 py-0.5 text-[11px] font-bold text-sky ring-1 ring-sky/40">
              VENTAJA DE TIEMPO
            </span>
          </div>
          <h3 class="mt-5 text-2xl font-bold text-white">Te anticipas a tu competencia</h3>
          <p class="mt-3 text-slate-300 leading-relaxed">
            ContRadar vigila SECOP I y II todos los días y detecta hasta los procesos en borrador —
            antes de su publicación oficial. Preparas tu propuesta mientras tu competencia espera a
            que el proceso salga.
          </p>
          <div class="mt-5 flex items-center gap-3">
            <span class="relative flex h-3 w-3">
              <span class="absolute inline-flex h-full w-full rounded-full bg-teal opacity-75 animate-ping"></span>
              <span class="relative inline-flex h-3 w-3 rounded-full bg-teal"></span>
            </span>
            <span class="text-sm font-semibold text-teal">Sistema activo ahora mismo</span>
          </div>
        </div>
      </div>

      <!-- CRM — big card -->
      <div class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-teal/20 to-teal/5 p-8 ring-2 ring-teal/40 card-hover" data-reveal data-delay="200">
        <div class="flex items-center gap-3">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-teal/20 text-teal">
            <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="18" height="18" rx="2"/>
              <path d="M3 9h18M9 21V9"/>
            </svg>
          </div>
          <span class="rounded-full bg-teal/30 px-2.5 py-0.5 text-[11px] font-bold text-teal ring-1 ring-teal/40">
            INCLUIDO EN EL PLAN
          </span>
        </div>
        <h3 class="mt-5 text-2xl font-bold text-white">Sistema de seguimiento integrado</h3>
        <p class="mt-3 text-slate-300 leading-relaxed">
          La alerta llega y entra directo al sistema. Tu equipo sabe en qué etapa
          está cada proceso, quién lo lleva y cuándo cierra. <strong class="text-white">Seguimiento de equipo incluido en el plan, sin integraciones extra.</strong>
        </p>
        <ul class="mt-5 space-y-2">
          {[
            "Etapas: Nueva → Revisando → Participamos → Ganada",
            "Asigna responsables por oportunidad",
            "Notas, adjuntos e historial de actividad",
            "Exporta el historial en Excel (Enterprise)"
          ].map(f => (
            <li class="flex items-center gap-2 text-sm text-slate-300">
              <svg class="h-4 w-4 shrink-0 text-teal" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M16.7 5.3a1 1 0 010 1.4l-7.5 7.5a1 1 0 01-1.4 0L3.3 9.7a1 1 0 011.4-1.4l3.1 3.1 6.8-6.8a1 1 0 011.4 0z" clip-rule="evenodd"/>
              </svg>
              {f}
            </li>
          ))}
        </ul>
      </div>

    </div>

    <!-- Small two: Score + Transparency -->
    <div class="mt-5 grid gap-5 sm:grid-cols-2">

      <div class="rounded-2xl bg-white/8 p-6 ring-1 ring-white/15 card-hover" data-reveal data-delay="300">
        <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-sky/20 text-sky">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
          </svg>
        </div>
        <h3 class="mt-3 text-base font-bold text-white">Score de relevancia</h3>
        <p class="mt-2 text-sm text-slate-300 leading-relaxed">
          Cada proceso recibe un puntaje según los datos de tu empresa —incluido tu RUP (experiencia y capacidad)—, sector, territorio y valor. Recibes las mejores oportunidades ordenadas, no una lista sin criterio.
        </p>
      </div>

      <div class="rounded-2xl bg-white/8 p-6 ring-1 ring-white/15 card-hover" data-reveal data-delay="400">
        <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-teal/20 text-teal">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
            <circle cx="12" cy="12" r="3"/>
          </svg>
        </div>
        <h3 class="mt-3 text-base font-bold text-white">Visibilidad total</h3>
        <p class="mt-2 text-sm text-slate-300 leading-relaxed">
          Ves cuántas oportunidades no entraron en tu plan. Te mostramos lo que <em>te estás perdiendo</em>, sin esconderlo.
        </p>
      </div>

    </div>
  </div>
</section>
