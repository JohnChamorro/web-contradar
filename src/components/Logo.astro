---
interface Props {
  class?: string;
  showIcon?: boolean;
  variant?: "dark" | "light";
}
const { class: className = "", showIcon = false, variant = "dark" } = Astro.props;
---

<span class={`inline-flex items-center gap-2.5 font-extrabold tracking-tight ${className}`}>
  {showIcon && (
    <img
      src={variant === "light" ? "/favicon-blanco.svg" : "/favicon.svg"}
      alt=""
      class="h-8 w-auto shrink-0"
      aria-hidden="true"
    />
  )}
  <span class={variant === "light" ? "text-white" : "text-navy"}>
    Cont<span class="text-sky">Radar</span>
  </span>
</span>
