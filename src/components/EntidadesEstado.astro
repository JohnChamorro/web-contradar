---
// EntidadesEstado.astro — muro de entidades públicas que licitan en SECOP.
// Legal: son NOMBRES de entidades públicas (información pública), no logos/escudos oficiales,
// y con aviso de no-afiliación para no implicar patrocinio ni relación comercial.
const entidades = [
  "INVÍAS",
  "ICBF",
  "Ministerio de Salud",
  "Ministerio de Defensa",
  "Policía Nacional",
  "Ejército Nacional",
  "Ecopetrol",
  "ANI — Infraestructura",
  "SENA",
  "Aeronáutica Civil",
  "UNGRD",
  "Fiscalía General",
];
---
<section class="border-y border-slate-100 bg-white">
  <div class="mx-auto max-w-6xl px-5 py-12 sm:px-8">
    <div class="mx-auto max-w-2xl text-center" data-reveal>
      <span class="rounded-full bg-navy/10 px-3 py-1 text-xs font-bold text-navy ring-1 ring-navy/15 uppercase tracking-wide">
        Con quién puedes contratar
      </span>
      <h2 class="mt-4 text-2xl font-bold tracking-tight text-navy sm:text-3xl">
        Miles de entidades del Estado licitan en SECOP
      </h2>
      <p class="mt-3 text-slate-600">
        Ministerios, agencias nacionales, fuerzas del Estado y hospitales publican procesos cada día.
        ContRadar te avisa en cuanto sale uno para tu empresa.
      </p>
    </div>

    <div class="mt-8 grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-4" data-reveal data-delay="100">
      {entidades.map((e) => (
        <div class="flex items-center gap-2.5 rounded-xl bg-slate-50 px-4 py-3 ring-1 ring-slate-100">
          <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-navy/5 text-navy">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 21h18M4 21V10l8-6 8 6v11M9 21v-6h6v6"/>
            </svg>
          </div>
          <span class="text-sm font-semibold leading-tight text-slate-600">{e}</span>
        </div>
      ))}
    </div>

    <!-- Territorial: general, no una por una -->
    <div class="mt-4 flex items-center gap-3 rounded-xl bg-navy px-5 py-4 text-white" data-reveal data-delay="150">
      <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-white/10 text-teal">
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 21h18M4 21V10l8-6 8 6v11M9 21v-6h6v6"/>
        </svg>
      </div>
      <p class="text-sm leading-snug">
        <strong>Y todas las alcaldías, gobernaciones y ciudades del país.</strong>
        <span class="text-slate-300">Cada municipio y departamento de Colombia contrata a través del SECOP.</span>
      </p>
    </div>

    <p class="mt-6 text-center text-xs text-slate-400">
      Entidades públicas que contratan a través del SECOP (información pública).
      No están afiliadas a ContRadar ni patrocinan el servicio.
    </p>
  </div>
</section>
