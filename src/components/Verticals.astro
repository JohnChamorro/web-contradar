---
import { VERTICALS } from "../data/content";
---

<section id="sectores" class="bg-white">
  <div class="mx-auto max-w-6xl px-5 py-20 sm:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold tracking-tight text-navy">Hecho para tu sector</h2>
      <p class="mt-3 text-lg text-slate-600">
        Cubrimos los 14 sectores del SECOP. Activas el tuyo y olvídate del resto.
      </p>
    </div>

    <div class="mt-12 grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-4">
      {VERTICALS.map((v) => (
        <div class="flex items-center gap-3 rounded-xl border border-slate-100 bg-slate-50 px-4 py-3.5 transition hover:border-sky/40 hover:bg-white hover:shadow-sm">
          <span class="text-2xl">{v.emoji}</span>
          <span class="text-sm font-medium text-slate-700">{v.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>
