---
import { STEPS } from "../data/content";
---

<section id="como-funciona" class="bg-slate-50">
  <div class="mx-auto max-w-6xl px-5 py-20 sm:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold tracking-tight text-navy">Cómo funciona</h2>
      <p class="mt-3 text-lg text-slate-600">Tres pasos. Lo configuras una vez y trabaja solo.</p>
    </div>

    <div class="mt-12 grid gap-6 md:grid-cols-3">
      {STEPS.map((s) => (
        <div class="relative rounded-2xl bg-white p-7 shadow-sm ring-1 ring-slate-100">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-sky/10 text-2xl font-bold text-sky">
            {s.n}
          </div>
          <h3 class="mt-5 text-lg font-semibold text-navy">{s.title}</h3>
          <p class="mt-2 text-slate-600">{s.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
