<section id="como-funciona" class="relative overflow-hidden bg-slate-50">
  <!-- Subtle background blobs -->
  <div class="pointer-events-none absolute left-0 top-1/2 -translate-x-2/3 h-80 w-80 rounded-full bg-teal/6 blur-3xl" aria-hidden="true"></div>
  <div class="pointer-events-none absolute right-0 bottom-0 translate-x-1/2 h-72 w-72 rounded-full bg-sky/6 blur-3xl" aria-hidden="true"></div>

  <div class="relative mx-auto max-w-6xl px-5 py-20 sm:px-8">

    <!-- Header -->
    <div class="mx-auto max-w-2xl text-center" data-reveal>
      <span class="rounded-full bg-navy/10 px-3 py-1 text-xs font-bold text-navy ring-1 ring-navy/15 uppercase tracking-wide">
        El flujo completo
      </span>
      <h2 class="mt-4 text-3xl font-extrabold tracking-tight text-navy sm:text-4xl text-wrap-balance">
        De la alerta al contrato ganado.<br/>
        <span class="text-teal">Sin salir de ContRadar.</span>
      </h2>
      <p class="mt-3 text-lg text-slate-600">
        Un solo flujo. Una sola herramienta. Sin dispersar información en correos,
        WhatsApps ni hojas de Excel.
      </p>
    </div>

    <!-- Progress bar (desktop) -->
    <div class="mt-10 hidden lg:flex items-center justify-center" data-reveal data-delay="50">
      <div class="flex w-full max-w-3xl items-center">
        {[1,2,3,4,5].map((n, i) => (
          <>
            <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-teal text-white text-xs font-extrabold shadow-md shadow-teal/30">
              {n}
            </div>
            {i < 4 && (
              <div class="flex-1 h-0.5 bg-gradient-to-r from-teal to-teal/40"></div>
            )}
          </>
        ))}
      </div>
    </div>

    <!-- Steps grid -->
    <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-5" data-reveal data-delay="100">
      {[
        {
          n: 1,
          badge: "ANTICIPACIÓN",
          badgeColor: "teal",
          icon: "M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z",
          title: "ContRadar detecta",
          desc: "Vigilamos SECOP I y SECOP II todos los días y detectamos hasta los procesos en borrador — antes de su publicación oficial.",
        },
        {
          n: 2,
          badge: "AUTOMÁTICO",
          badgeColor: "teal",
          icon: "M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z",
          title: "Alerta a tu equipo",
          desc: "La oportunidad llega a tu correo y entra automáticamente al sistema de tu equipo. Nadie tiene que hacer nada manualmente.",
        },
        {
          n: 3,
          badge: "EN CONTRADAR",
          badgeColor: "sky",
          icon: "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z",
          title: "El equipo decide",
          desc: "Revisas en ContRadar, asignas un responsable y el equipo decide si participan. Todos ven el mismo tablero al mismo tiempo.",
        },
        {
          n: 4,
          badge: "EN CONTRADAR",
          badgeColor: "sky",
          icon: "M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z",
          title: "Preparan la propuesta",
          desc: "Notas, adjuntos, plazos de cierre. Todo centralizado en la tarjeta. Sin correos perdidos. Sin hojas de cálculo separadas.",
        },
        {
          n: 5,
          badge: "HISTORIAL COMPLETO",
          badgeColor: "navy",
          icon: "M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z",
          title: "Contrato ganado",
          desc: "El historial queda guardado en ContRadar. Aprendes qué oportunidades conviene perseguir y qué propuestas ganan.",
        },
      ].map((step, i) => (
        <div
          class="relative rounded-2xl bg-white p-6 ring-1 ring-slate-100 card-hover flex flex-col"
          data-reveal
          data-delay={String(i * 80)}
        >
          <!-- Step number (mobile / left column visual) -->
          <div class="flex items-center gap-2.5 mb-4">
            <div class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-teal text-white text-xs font-extrabold lg:hidden">
              {step.n}
            </div>
            <span class={`rounded-full px-2 py-0.5 text-[9px] font-bold uppercase tracking-widest ${
              step.badgeColor === 'teal' ? 'bg-teal/10 text-teal' :
              step.badgeColor === 'sky'  ? 'bg-sky/10 text-sky'   :
                                           'bg-navy/10 text-navy'
            }`}>
              {step.badge}
            </span>
          </div>

          <!-- Icon -->
          <div class={`flex h-10 w-10 items-center justify-center rounded-xl mb-4 ${
            step.badgeColor === 'teal' ? 'bg-teal/10 text-teal' :
            step.badgeColor === 'sky'  ? 'bg-sky/10 text-sky'   :
                                         'bg-navy/10 text-navy'
          }`}>
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d={step.icon}/>
            </svg>
          </div>

          <h3 class="font-bold text-navy mb-2">{step.title}</h3>
          <p class="text-sm text-slate-500 leading-relaxed flex-1">{step.desc}</p>

          <!-- Connector arrow (desktop only, not on last step) -->
          {i < 4 && (
            <div class="absolute -right-2.5 top-1/2 -translate-y-1/2 z-10 hidden lg:flex h-5 w-5 items-center justify-center rounded-full bg-slate-100 ring-1 ring-slate-200 shadow-sm">
              <svg class="h-3 w-3 text-slate-400" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
              </svg>
            </div>
          )}
        </div>
      ))}
    </div>

    <!-- Bottom tagline -->
    <div class="mt-10 rounded-2xl bg-navy px-8 py-6 text-center" data-reveal data-delay="300">
      <p class="text-base font-semibold text-white sm:text-lg">
        La licitación llega a ContRadar <span class="text-teal">antes que a cualquier buscador público.</span>
        Tu equipo la gestiona en ContRadar.
        El contrato se cierra en ContRadar.
        <span class="text-slate-400 font-normal text-sm block mt-1">Un solo lugar. Cero información dispersa.</span>
      </p>
    </div>

  </div>
</section>
