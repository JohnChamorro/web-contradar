---
import Logo from "./Logo.astro";
import { LOGIN_URL } from "../consts";

const links = [
  { href: "/funcionalidades",  label: "Funcionalidades" },
  { href: "/precios",          label: "Precios" },
  { href: "/#diagnostico",     label: "Diagnóstico gratis", highlight: true },
  { href: "/sectores",         label: "Sectores" },
  { href: "/guias",            label: "Guías" },
  { href: "/nosotros",         label: "Nosotros" },
  { href: "/ayuda",            label: "Ayuda" },
];
---

<header class="sticky top-0 z-50 bg-navy-deep/95 backdrop-blur-md border-b border-white/10">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-5 py-3 sm:px-8">

    <a href="/" class="shrink-0">
      <Logo showIcon={true} variant="light" />
    </a>

    <nav class="hidden items-center gap-6 lg:flex">
      {links.map((l) => (
        <a
          href={l.href}
          class={l.highlight
            ? "text-sm font-bold text-teal transition hover:text-teal/80"
            : "text-sm font-medium text-slate-300 transition hover:text-white"}
        >
          {l.label}
        </a>
      ))}
    </nav>

    <div class="hidden items-center gap-3 md:flex">
      <a href={LOGIN_URL} class="text-sm font-semibold text-slate-300 transition hover:text-white">
        Ingresar
      </a>
      <a
        href="#solicitar"
        class="rounded-lg bg-sky px-4 py-2 text-sm font-bold text-white shadow-md shadow-sky/30 transition hover:bg-sky/90"
      >
        Prueba gratis 10 días
      </a>
    </div>

    <button id="nav-toggle" class="text-white md:hidden" aria-label="menú" aria-expanded="false">
      <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>
  </div>

  <div id="nav-mobile" class="hidden border-t border-white/10 bg-navy-deep px-5 py-3 md:hidden">
    {links.map((l) => (
      <a href={l.href} class="nav-mobile-link block py-2.5 text-sm font-medium text-slate-300 hover:text-white">
        {l.label}
      </a>
    ))}
    <div class="mt-2 flex gap-3 border-t border-white/10 pt-3">
      <a href={LOGIN_URL} class="flex-1 rounded-lg border border-white/20 px-4 py-2 text-center text-sm font-semibold text-white">
        Ingresar
      </a>
      <a href="#solicitar" class="nav-mobile-link flex-1 rounded-lg bg-sky px-4 py-2 text-center text-sm font-bold text-white">
        Prueba gratis 10 días
      </a>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById("nav-toggle");
  const mobile = document.getElementById("nav-mobile");

  toggle?.addEventListener("click", () => {
    const open = mobile?.classList.toggle("hidden") === false;
    toggle.setAttribute("aria-expanded", String(open));
  });
  document.querySelectorAll(".nav-mobile-link").forEach((a) =>
    a.addEventListener("click", () => mobile?.classList.add("hidden")),
  );
</script>
