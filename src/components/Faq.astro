---
import { FAQ } from "../data/content";
---

<section id="faq" class="bg-white">
  <div class="mx-auto max-w-3xl px-5 py-20 sm:px-8">
    <h2 class="text-center text-3xl font-bold tracking-tight text-navy">Preguntas frecuentes</h2>
    <div class="mt-10 divide-y divide-slate-100 rounded-2xl border border-slate-100">
      {FAQ.map((it, i) => (
        <details class="group" open={i === 0}>
          <summary class="flex cursor-pointer items-center justify-between gap-4 px-5 py-4 font-semibold text-navy marker:content-none">
            {it.q}
            <span class="text-xl text-sky transition-transform group-open:rotate-45">+</span>
          </summary>
          <p class="px-5 pb-5 text-slate-600">{it.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>
