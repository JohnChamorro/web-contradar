<section class="relative overflow-hidden bg-slate-50">
  <!-- Lateral decoration -->
  <div class="pointer-events-none absolute left-0 top-0 -translate-x-2/3 h-80 w-80 rounded-full bg-sky/8 blur-3xl" aria-hidden="true"></div>
  <div class="pointer-events-none absolute right-0 bottom-0 translate-x-2/3 h-72 w-72 rounded-full bg-teal/8 blur-3xl" aria-hidden="true"></div>
  <div class="mx-auto max-w-6xl px-5 py-20 sm:px-8">

    <!-- Heading -->
    <div class="mx-auto max-w-2xl text-center" data-reveal>
      <h2 class="text-3xl font-bold tracking-tight text-navy">
        Revisar el SECOP a mano es perder el tiempo
      </h2>
      <p class="mt-3 text-lg text-slate-600">
        Cada día se publican cientos de contratos. Encontrar los que son para tu empresa — a tiempo — es imposible sin una herramienta.
      </p>
    </div>

    <!-- 3 problem cards -->
    <div class="mt-10 grid gap-4 sm:grid-cols-3" data-reveal data-delay="100">
      {[
        {
          icon: "M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z",
          title: "Llegas tarde",
          desc: "Cuando encuentras la licitación en el portal, tu competencia ya lleva días preparando propuesta.",
        },
        {
          icon: "M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z",
          title: "Demasiado ruido",
          desc: "El portal muestra todo sin filtrar. Revisas decenas de contratos que no tienen nada que ver con tu empresa.",
        },
        {
          icon: "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z",
          title: "Información dispersa",
          desc: "Las oportunidades llegan al correo de una persona. El equipo no tiene visibilidad y los contratos se escapan.",
        },
      ].map(card => (
        <div class="relative overflow-hidden rounded-2xl bg-white p-6 ring-1 ring-slate-100 card-hover">
          <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-red-50 text-red-400">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d={card.icon}/>
            </svg>
          </div>
          <h3 class="mt-3.5 font-bold text-slate-800">{card.title}</h3>
          <p class="mt-1.5 text-sm text-slate-500 leading-relaxed">{card.desc}</p>
        </div>
      ))}
    </div>

    <!-- Counter + solution row -->
    <div class="mt-10 grid items-center gap-12 lg:grid-cols-2">

      <!-- Radar graphic + counter -->
      <div class="flex flex-col items-center justify-center" data-reveal>
        <div class="relative flex h-48 w-48 items-center justify-center sm:h-60 sm:w-60">
          <span class="absolute h-full w-full rounded-full border-2 border-sky/30 radar-ring" aria-hidden="true"></span>
          <span class="absolute h-full w-full rounded-full border-2 border-sky/20 radar-ring-2" aria-hidden="true"></span>
          <span class="absolute h-28 w-28 rounded-full bg-sky/10 sm:h-36 sm:w-36" aria-hidden="true"></span>
          <div class="relative text-center">
            <div id="noise-counter" class="text-6xl font-extrabold text-navy sm:text-7xl" aria-label="95 por ciento">
              0<span class="text-sky">%</span>
            </div>
            <div class="mt-1 text-sm font-semibold text-slate-500">del SECOP es ruido</div>
          </div>
        </div>
        <p class="mt-5 max-w-xs text-center text-sm text-slate-500 leading-relaxed">
          De todo lo que publica el Estado, solo una fracción encaja con tu empresa. ContRadar hace ese filtro por ti.
        </p>
      </div>

      <!-- Solution copy -->
      <div data-reveal data-delay="200">
        <span class="rounded-full bg-teal/15 px-3 py-1 text-xs font-semibold text-teal ring-1 ring-teal/30">
          La solución
        </span>
        <h3 class="mt-4 text-2xl font-bold tracking-tight text-navy">
          ContRadar hace ese filtro por ti, automáticamente
        </h3>
        <p class="mt-4 text-lg text-slate-600">
          Configuras tus búsquedas una vez y ContRadar se encarga del resto. Recibes solo las oportunidades que encajan con tu empresa.
        </p>
        <ul class="mt-5 space-y-3">
          {[
            "Sin revisar el portal todos los días",
            "Sin perder licitaciones por llegar tarde",
            "Sin leer procesos que no son para ti",
            "Con tu equipo siempre coordinado",
          ].map(item => (
            <li class="flex items-center gap-2.5 text-slate-700">
              <svg class="h-5 w-5 shrink-0 text-teal" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M16.7 5.3a1 1 0 010 1.4l-7.5 7.5a1 1 0 01-1.4 0L3.3 9.7a1 1 0 011.4-1.4l3.1 3.1 6.8-6.8a1 1 0 011.4 0z" clip-rule="evenodd"/>
              </svg>
              {item}
            </li>
          ))}
        </ul>

        <a href="#solicitar" class="mt-7 inline-flex items-center gap-2 rounded-xl bg-navy px-6 py-3 text-sm font-bold text-white shadow-sm transition hover:bg-navy-deep">
          Empezar ahora →
        </a>
      </div>

    </div>

  </div>
</section>

<script>
  const el = document.getElementById("noise-counter");
  if (el) {
    const target = 95;
    let started = false;
    const observer = new IntersectionObserver(([entry]) => {
      if (entry.isIntersecting && !started) {
        started = true;
        let current = 0;
        const step = () => {
          current = Math.min(current + 2, target);
          el.innerHTML = `${current}<span class="text-sky">%</span>`;
          if (current < target) requestAnimationFrame(step);
        };
        requestAnimationFrame(step);
      }
    }, { threshold: 0.5 });
    observer.observe(el);
  }
</script>
