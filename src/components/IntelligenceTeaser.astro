<section class="relative overflow-hidden bg-navy-deep text-white">
  <!-- Subtle grid -->
  <div class="pointer-events-none absolute inset-0 opacity-[0.04]" aria-hidden="true">
    <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="grid-intel" width="40" height="40" patternUnits="userSpaceOnUse">
          <path d="M 40 0 L 0 0 0 40" fill="none" stroke="white" stroke-width="0.5"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#grid-intel)"/>
    </svg>
  </div>
  <!-- Glow -->
  <div class="pointer-events-none absolute top-0 left-1/2 -translate-x-1/2 h-64 w-64 rounded-full bg-sky/20 blur-3xl" aria-hidden="true"></div>

  <div class="relative mx-auto max-w-5xl px-5 py-20 sm:px-8">

    <div class="text-center" data-reveal>
      <span class="inline-flex items-center gap-1.5 rounded-full bg-sky/20 px-3 py-1 text-xs font-bold text-sky ring-1 ring-sky/30 uppercase tracking-wide">
        <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M13 10V3L4 14h7v7l9-11h-7z"/>
        </svg>
        Próximamente
      </span>
      <h2 class="mt-5 text-3xl font-extrabold tracking-tight sm:text-4xl">
        Inteligencia de licitaciones
      </h2>
      <p class="mt-3 mx-auto max-w-xl text-lg text-slate-300">
        El siguiente nivel de ContRadar: no solo recibir alertas, sino entender el mercado
        y ganar más con los datos que ya tienes.
      </p>
    </div>

    <!-- Locked feature cards -->
    <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-4" data-reveal data-delay="150">
      {[
        {
          icon: "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z",
          title: "Análisis competitivo",
          desc: "¿Quiénes ganan contratos en tu sector y territorio?",
        },
        {
          icon: "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-2 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4",
          title: "Inteligencia de entidades",
          desc: "¿Cuánto invierte cada entidad? ¿Con qué frecuencia publica?",
        },
        {
          icon: "M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z",
          title: "Win rate vs el mercado",
          desc: "Tu tasa de adjudicación comparada con el sector.",
        },
        {
          icon: "M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z",
          title: "Detección de oportunidades",
          desc: "Entidades que nunca has ofertado pero encajan contigo.",
        },
      ].map(f => (
        <div class="relative rounded-2xl bg-white/5 p-5 ring-1 ring-white/10 overflow-hidden">
          <!-- Lock overlay -->
          <div class="absolute top-3 right-3 flex h-6 w-6 items-center justify-center rounded-full bg-white/10">
            <svg class="h-3.5 w-3.5 text-slate-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
              <path d="M7 11V7a5 5 0 0110 0v4"/>
            </svg>
          </div>
          <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-sky/15 text-sky">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d={f.icon}/>
            </svg>
          </div>
          <h3 class="mt-3.5 text-sm font-bold text-white">{f.title}</h3>
          <p class="mt-1.5 text-sm text-slate-400 leading-relaxed">{f.desc}</p>
        </div>
      ))}
    </div>

    <p class="mt-8 text-center text-sm text-slate-400" data-reveal data-delay="200">
      ¿Te interesa acceso anticipado?
      <a href="#solicitar" class="ml-1 font-semibold text-sky hover:text-sky/80 transition">
        Menciónalo en tu solicitud →
      </a>
    </p>

  </div>
</section>
