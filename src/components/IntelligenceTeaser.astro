---
// IntelligenceTeaser.astro — módulos de inteligencia YA disponibles (no "próximamente").
const modulos = [
  {
    icon: "M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z",
    tag: "Todos los planes",
    title: "Análisis de mercado En Vivo",
    desc: "El pulso de la contratación de tu sector, en vivo. Básico en Alerta, completo en Ventaja y Dominio.",
  },
  {
    icon: "M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z",
    tag: "Ventaja y Dominio",
    title: "Análisis histórico 2023-2025",
    desc: "Tres años de adjudicaciones para entender montos, entidades y estacionalidad de tu mercado.",
  },
  {
    icon: "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z",
    tag: "Dominio",
    title: "Análisis de Competencia",
    desc: "Quién ganó procesos como el tuyo, a qué precio ofertaron y con qué historial. Ofertas con argumento de precio.",
  },
  {
    icon: "M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z",
    tag: "Dominio",
    title: "Buscador PAA",
    desc: "El Plan Anual de Adquisiciones es lo que el Estado planea comprar en el año. Te avisamos desde que la oportunidad se planea — meses antes de que abra.",
  },
  {
    icon: "M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z",
    tag: "Ventaja y Dominio",
    title: "Reporte ROI mensual",
    desc: "Cada mes, cuánto valor en oportunidades gestionaste y cómo rinde tu operación de licitaciones.",
  },
];
---
<section class="relative overflow-hidden bg-navy-deep text-white">
  <!-- Subtle grid -->
  <div class="pointer-events-none absolute inset-0 opacity-[0.04]" aria-hidden="true">
    <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="grid-intel" width="40" height="40" patternUnits="userSpaceOnUse">
          <path d="M 40 0 L 0 0 0 40" fill="none" stroke="white" stroke-width="0.5"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#grid-intel)"/>
    </svg>
  </div>
  <div class="pointer-events-none absolute top-0 left-1/2 -translate-x-1/2 h-64 w-64 rounded-full bg-teal/15 blur-3xl" aria-hidden="true"></div>

  <div class="relative mx-auto max-w-5xl px-5 py-20 sm:px-8">

    <div class="text-center" data-reveal>
      <span class="inline-flex items-center gap-1.5 rounded-full bg-teal/20 px-3 py-1 text-xs font-bold text-teal ring-1 ring-teal/30 uppercase tracking-wide">
        <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M13 10V3L4 14h7v7l9-11h-7z"/>
        </svg>
        Módulos de inteligencia
      </span>
      <h2 class="mt-5 text-3xl font-extrabold tracking-tight sm:text-4xl">
        Inteligencia para licitaciones, no solo alertas
      </h2>
      <p class="mt-3 mx-auto max-w-xl text-lg text-slate-300">
        Entiende tu mercado, mide a tu competencia y adelántate a lo que el Estado va a comprar.
      </p>
    </div>

    <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-3" data-reveal data-delay="150">
      {modulos.map((f) => (
        <div class="rounded-2xl bg-white/5 p-5 ring-1 ring-white/10">
          <div class="flex items-center justify-between gap-2">
            <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-teal/15 text-teal">
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d={f.icon}/>
              </svg>
            </div>
            <span class="rounded-full bg-white/10 px-2.5 py-0.5 text-[9px] font-extrabold uppercase tracking-widest text-slate-300">{f.tag}</span>
          </div>
          <h3 class="mt-3.5 text-sm font-bold text-white">{f.title}</h3>
          <p class="mt-1.5 text-sm text-slate-400 leading-relaxed">{f.desc}</p>
        </div>
      ))}
    </div>

    <p class="mt-8 text-center text-sm text-slate-400" data-reveal data-delay="200">
      El detalle por plan está en
      <a href="/precios" class="ml-1 font-semibold text-teal hover:text-teal/80 transition">precios →</a>
    </p>

  </div>
</section>
