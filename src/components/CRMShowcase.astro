<section class="relative overflow-hidden bg-white">
  <!-- Lateral decorations -->
  <div class="pointer-events-none absolute left-0 top-1/3 -translate-x-2/3 h-96 w-96 rounded-full bg-teal/8 blur-3xl" aria-hidden="true"></div>
  <div class="pointer-events-none absolute right-0 bottom-1/4 translate-x-2/3 h-80 w-80 rounded-full bg-sky/8 blur-3xl" aria-hidden="true"></div>

  <div class="mx-auto max-w-6xl px-5 py-20 sm:px-8">

    <!-- Header -->
    <div class="mx-auto max-w-2xl text-center" data-reveal>
      <span class="rounded-full bg-teal/15 px-3 py-1 text-xs font-semibold text-teal ring-1 ring-teal/30">
        Gestión de licitaciones
      </span>
      <h2 class="mt-4 text-3xl font-bold tracking-tight text-navy sm:text-4xl">
        Toda tu organización,<br class="hidden sm:block"/>
        <span class="text-teal">coordinada para ganar contratos</span>
      </h2>
      <p class="mt-3 text-lg text-slate-600">
        ContRadar no es solo alertas. Es la plataforma donde tu equipo recibe, gestiona, asigna
        y cierra contratos públicos — sin correos dispersos, sin hojas de cálculo, sin perder el rastro.
      </p>
    </div>

    <!-- 3 org-level metric cards -->
    <div class="mt-10 grid gap-4 sm:grid-cols-3" data-reveal data-delay="100">
      {[
        {
          icon: "M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2",
          color: "teal",
          title: "Seguimiento completo visible",
          desc: "5 etapas: Nueva, Revisando, Participamos, Ganadas, En ejecución. Todo el equipo ve el mismo tablero.",
        },
        {
          icon: "M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z",
          color: "sky",
          title: "Cada persona sabe su rol",
          desc: "Asigna responsables por oportunidad. El gerente ve el resumen; cada persona, sus tareas.",
        },
        {
          icon: "M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z",
          color: "teal",
          title: "Historial de cada decisión",
          desc: "Notas, adjuntos y registro de actividad en cada tarjeta. Todo queda guardado, nada se pierde.",
        },
      ].map(card => (
        <div class="relative overflow-hidden rounded-2xl bg-slate-50 p-6 ring-1 ring-slate-100 card-hover">
          <div class={`flex h-10 w-10 items-center justify-center rounded-xl ${card.color === 'teal' ? 'bg-teal/10 text-teal' : 'bg-sky/10 text-sky'}`}>
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d={card.icon}/>
            </svg>
          </div>
          <h3 class="mt-3.5 font-bold text-navy">{card.title}</h3>
          <p class="mt-1.5 text-sm text-slate-600 leading-relaxed">{card.desc}</p>
        </div>
      ))}
    </div>

    <!-- Main 2-col: copy | screenshot -->
    <div class="mt-12 grid items-center gap-12 lg:grid-cols-2">

      <!-- Copy -->
      <div data-reveal data-delay="100">
        <h3 class="text-2xl font-bold tracking-tight text-navy">
          Del correo al contrato ganado,<br/>
          <span class="text-teal">sin salir de ContRadar</span>
        </h3>
        <p class="mt-4 text-lg text-slate-600">
          Cuando llega una alerta, la oportunidad entra directo al sistema de seguimiento.
          El equipo la revisa, decide si participa, sube la propuesta y hace
          el seguimiento hasta la adjudicación — todo en un solo lugar.
        </p>

        <ul class="mt-7 space-y-4">
          {[
            {
              icon: "M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2",
              label: "Tablero de oportunidades",
              desc: "5 etapas desde que llega la alerta hasta que se cierra el contrato",
            },
            {
              icon: "M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z",
              label: "Asignaciones por persona",
              desc: "Cada licitación tiene responsable y fecha de asignación; el gerente ve todo el tablero",
            },
            {
              icon: "M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.86 9.86 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z",
              label: "Comentarios con @menciones",
              desc: "El equipo conversa en la tarjeta: mencionas a alguien y le llega su notificación",
            },
            {
              icon: "M7 7h.01M7 3h5a1.99 1.99 0 011.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.99 1.99 0 013 12V7a4 4 0 014-4z",
              label: "Etiquetas y nombres propios",
              desc: "Marca el interés (alta/media), ponle tu nombre interno a cada proceso y filtra por lo tuyo",
            },
            {
              icon: "M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z",
              label: "Documentos del proceso, organizados",
              desc: "Pliegos y anexos de SECOP con estado leído → listo → enviado, descarga masiva e historial",
            },
            {
              icon: "M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z",
              label: "Exporta el seguimiento completo",
              desc: "Archivo Excel con el historial de toda la organización (Dominio)",
            },
          ].map(f => (
            <li class="flex items-start gap-3.5">
              <div class="mt-0.5 flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-teal/10 text-teal">
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <path d={f.icon}/>
                </svg>
              </div>
              <div>
                <div class="font-semibold text-navy">{f.label}</div>
                <div class="text-sm text-slate-500">{f.desc}</div>
              </div>
            </li>
          ))}
        </ul>

        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a href="#solicitar" class="inline-block rounded-xl bg-teal px-6 py-3 text-sm font-bold text-white shadow-sm shadow-teal/30 transition hover:bg-teal/90">
            Quiero gestionar mi equipo →
          </a>
          <a href="#producto" class="inline-block rounded-xl border border-teal/30 px-6 py-3 text-sm font-semibold text-teal transition hover:bg-teal/5">
            Ver el sistema
          </a>
        </div>
      </div>

      <!-- Screenshot -->
      <div class="relative" data-reveal data-delay="250">
        <div class="absolute inset-0 scale-95 rounded-2xl bg-teal/20 blur-2xl" aria-hidden="true"></div>

        <div class="relative overflow-hidden rounded-2xl shadow-2xl ring-1 ring-slate-200">
          <!-- Browser bar -->
          <div class="flex items-center gap-1.5 bg-slate-800 px-4 py-2.5">
            <span class="h-3 w-3 rounded-full bg-red-400"></span>
            <span class="h-3 w-3 rounded-full bg-yellow-400"></span>
            <span class="h-3 w-3 rounded-full bg-green-400"></span>
            <div class="ml-3 flex-1 rounded bg-slate-700 px-3 py-1 text-[11px] text-slate-400">
              app.contradar.com.co/oportunidades
            </div>
          </div>
          <video
            autoplay loop muted playsinline preload="metadata"
            poster="/Seguimiento.png"
            class="w-full"
            aria-label="Tablero de seguimiento de ContRadar en uso: tarjetas, responsables y documentos"
          >
            <source src="/SeccionSeguimiento.mp4" type="video/mp4" />
          </video>
        </div>

        <!-- Floating badge -->
        <div class="absolute -bottom-4 -left-4 rounded-xl bg-white px-4 py-3 shadow-lg ring-1 ring-slate-100 float-card-slow">
          <div class="flex items-center gap-2">
            <span class="text-xl">🏆</span>
            <div>
              <div class="text-xs font-bold text-navy">Ganadas este mes</div>
              <div class="text-lg font-extrabold text-teal">$4.850.000.000</div>
            </div>
          </div>
        </div>

        <!-- Second floating badge -->
        <div class="absolute -top-3 -right-3 rounded-xl bg-navy px-3.5 py-2.5 shadow-lg float-card-delay">
          <div class="flex items-center gap-2">
            <svg class="h-4 w-4 text-teal" viewBox="0 0 20 20" fill="currentColor">
              <path d="M9 6a3 3 0 11-6 0 3 3 0 016 0zM17 6a3 3 0 11-6 0 3 3 0 016 0zM12.93 17c.046-.327.07-.66.07-1a6.97 6.97 0 00-1.5-4.33A5 5 0 0119 16v1h-6.07zM6 11a5 5 0 015 5v1H1v-1a5 5 0 015-5z"/>
            </svg>
            <div>
              <div class="text-[10px] font-semibold text-slate-400">Equipo activo</div>
              <div class="text-xs font-bold text-white">5 usuarios</div>
            </div>
          </div>
        </div>

      </div>

    </div>

  </div>
</section>
