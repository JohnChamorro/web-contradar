---
// EstudioFinanciero.astro — oferta concierge: estudio a la medida de la empresa
// (habilitantes financieros, perfil, estrategia de oferta). Contacto a soporte.
import { CONTACT_EMAIL } from "../consts";
const subject = encodeURIComponent("Quiero un estudio para mi empresa");
---
<section id="estudio" class="bg-slate-50">
  <div class="mx-auto max-w-6xl px-5 py-16 sm:px-8">
    <div class="overflow-hidden rounded-3xl bg-white ring-1 ring-slate-200 shadow-sm">
      <div class="grid items-center gap-8 p-8 sm:p-10 lg:grid-cols-[1.3fr_auto]">
        <div>
          <span class="inline-flex items-center gap-2 rounded-full bg-teal/12 px-3 py-1 text-[10px] font-extrabold uppercase tracking-widest text-teal ring-1 ring-teal/20">
            Estudio a la medida
          </span>
          <h2 class="mt-4 text-2xl font-extrabold leading-snug text-navy sm:text-3xl text-wrap-balance">
            ¿Qué te falta para ganar más licitaciones?
          </h2>
          <p class="mt-4 max-w-xl text-base leading-relaxed text-slate-600">
            Hacemos un estudio a la medida de tu empresa: dónde estás perdiendo, qué habilitantes
            financieros te frenan, qué ajustar en tu perfil y en tu estrategia de oferta para
            mejorar tus posibilidades. Lo armamos contigo, con datos — no con corazonadas.
          </p>
          <ul class="mt-5 grid gap-2 sm:grid-cols-2">
            {[
              "Diagnóstico de tu huella real en el SECOP",
              "Habilitantes financieros y capacidad (RUP / K residual)",
              "Contra quién compites y por qué te ganan",
              "Qué cambiar para ser más competitivo en precio",
            ].map((t) => (
              <li class="flex items-start gap-2.5 text-sm text-slate-700">
                <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-sky/12 text-sky">
                  <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                </span>
                {t}
              </li>
            ))}
          </ul>
        </div>
        <div class="text-center sm:shrink-0">
          <a href={`mailto:${CONTACT_EMAIL}?subject=${subject}`}
            class="inline-flex items-center gap-2 rounded-xl bg-navy px-6 py-4 text-sm font-bold text-white shadow-lg transition hover:bg-navy-deep whitespace-nowrap">
            Escríbenos a soporte →
          </a>
          <p class="mt-3 text-xs text-slate-400">{CONTACT_EMAIL}</p>
        </div>
      </div>
    </div>
  </div>
</section>
