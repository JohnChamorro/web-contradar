---
import { PLANS } from "../data/content";
---

<section id="precios" class="bg-slate-50">
  <div class="mx-auto max-w-6xl px-5 py-20 sm:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold tracking-tight text-navy">Precios claros, sin sorpresas</h2>
      <p class="mt-3 text-lg text-slate-600">
        Elige el plan según cuántas oportunidades quieras seguir y qué tan rápido.
      </p>
    </div>

    <div class="mt-12 grid items-start gap-6 lg:grid-cols-3">
      {PLANS.map((p) => (
        <div
          class={`relative rounded-2xl bg-white p-7 shadow-sm transition ${
            p.featured ? "ring-2 ring-sky shadow-lg lg:-translate-y-3" : "ring-1 ring-slate-200"
          }`}
        >
          {p.featured && (
            <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-sky px-3 py-1 text-xs font-bold text-navy-deep">
              Más popular
            </span>
          )}
          <h3 class="text-lg font-bold text-navy">{p.name}</h3>
          <p class="mt-1 text-sm text-slate-500">{p.tagline}</p>
          <div class="mt-5 flex items-baseline gap-1">
            <span class="text-4xl font-extrabold tracking-tight text-navy">{p.price}</span>
            <span class="text-sm text-slate-500">/mes</span>
          </div>

          <ul class="mt-6 space-y-3">
            {p.features.map((f) => (
              <li class="flex items-start gap-2.5 text-sm text-slate-600">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-teal" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M16.7 5.3a1 1 0 010 1.4l-7.5 7.5a1 1 0 01-1.4 0L3.3 9.7a1 1 0 011.4-1.4l3.1 3.1 6.8-6.8a1 1 0 011.4 0z" clip-rule="evenodd"></path>
                </svg>
                <span>{f}</span>
              </li>
            ))}
          </ul>

          <a
            href="#solicitar"
            class={`mt-7 block rounded-xl px-5 py-3 text-center text-sm font-semibold transition ${
              p.featured
                ? "bg-navy text-white hover:bg-navy-deep"
                : "border border-navy text-navy hover:bg-navy hover:text-white"
            }`}
          >
            Solicitar acceso
          </a>
        </div>
      ))}
    </div>

    <p class="mt-8 text-center text-sm text-slate-500">
      ¿Necesitas algo a la medida? Escríbenos y armamos el plan ideal para tu empresa.
    </p>
  </div>
</section>
