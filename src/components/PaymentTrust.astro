---
// PaymentTrust.astro — sello de confianza de pagos: Wompi (pasarela de Bancolombia).
// Espeja el componente del producto (contradar/frontend/src/components/PaymentTrust.tsx).
//
// Los medios van como glifos BLANCOS en círculo negro — todos iguales, como el arte
// oficial de Wompi. Se dibujan inline: los logos a color no sobreviven el negativo
// (se aplanan a manchas). Visa y Mastercard usan su trazo monocromo real; Nequi y PSE
// van como palabra (igual que Wompi hace con "Clave" en su propio arte).
//
// SIN sello PCI: esa certificación es de Wompi, no nuestra — exhibirla junto a nuestra
// marca podría leerse como que ContRadar está certificado (publicidad engañosa).
//
// Ajustado a Colombia: PSE, no "Sistema Clave" (ese arte es de Panamá).

interface Props {
  variant?: "banner" | "platform";
  class?: string;
}
const { variant = "banner", class: className = "" } = Astro.props;

const WOMPI_LOGO = "/LogosWompi/wompi-logo.svg";
const BANCOLOMBIA = "/LogosWompi/bancolombia.png"; // versión blanca → se invierte para fondo claro

const VISA_PATH =
  "M9.112 8.262L5.97 15.758H3.92L2.374 9.775c-.094-.368-.175-.503-.461-.658C1.447 8.864.677 8.627 0 8.479l.046-.217h3.3a.904.904 0 01.894.764l.817 4.338 2.018-5.102zm8.033 5.049c.008-1.979-2.736-2.088-2.717-2.972.006-.269.262-.555.822-.628a3.66 3.66 0 011.913.336l.34-1.59a5.207 5.207 0 00-1.814-.333c-1.917 0-3.266 1.02-3.278 2.479-.012 1.079.963 1.68 1.698 2.04.756.367 1.01.603 1.006.931-.005.504-.602.725-1.16.734-.975.015-1.54-.263-1.992-.473l-.351 1.642c.453.208 1.289.39 2.156.398 2.037 0 3.37-1.006 3.377-2.564m5.061 2.447H24l-1.565-7.496h-1.656a.883.883 0 00-.826.55l-2.909 6.946h2.036l.405-1.12h2.488zm-2.163-2.656l1.02-2.815.588 2.815zm-8.16-4.84l-1.603 7.496H8.34l1.605-7.496z";
const MASTERCARD_PATH =
  "M11.343 18.031c.058.049.12.098.181.146-1.177.783-2.59 1.238-4.107 1.238C3.32 19.416 0 16.096 0 12c0-4.095 3.32-7.416 7.416-7.416 1.518 0 2.931.456 4.105 1.238-.06.051-.12.098-.165.15C9.6 7.489 8.595 9.688 8.595 12c0 2.311 1.001 4.51 2.748 6.031zm5.241-13.447c-1.52 0-2.931.456-4.105 1.238.06.051.12.098.165.15C14.4 7.489 15.405 9.688 15.405 12c0 2.31-1.001 4.507-2.748 6.031-.058.049-.12.098-.181.146 1.177.783 2.588 1.238 4.107 1.238C20.68 19.416 24 16.096 24 12c0-4.094-3.32-7.416-7.416-7.416zM12 6.174c-.096.075-.189.15-.28.231C10.156 7.764 9.169 9.765 9.169 12c0 2.236.987 4.236 2.551 5.595.09.08.185.158.28.232.096-.074.189-.152.28-.232 1.563-1.359 2.551-3.359 2.551-5.595 0-2.235-.987-4.236-2.551-5.595-.09-.08-.184-.156-.28-.231z";

const METHODS = [
  { label: "Crédito y débito", kind: "card" },
  { label: "Nequi", kind: "text", text: "Nequi", size: "text-[11px]" },
  { label: "PSE", kind: "text", text: "pse", size: "text-[14px]" },
  { label: "Visa", kind: "visa" },
  { label: "Mastercard", kind: "mastercard" },
];
---

{
  variant === "platform" ? (
    <span class={`inline-flex items-center gap-2 whitespace-nowrap ${className}`}>
      <img src={WOMPI_LOGO} alt="Wompi" class="h-5 w-auto" />
      <span class="text-[10px] leading-tight text-slate-400">Una idea de</span>
      <img src={BANCOLOMBIA} alt="Bancolombia" class="h-4 w-auto opacity-60 [filter:brightness(0)]" />
    </span>
  ) : (
    <div class={`rounded-2xl border border-slate-200 bg-white p-5 shadow-sm sm:p-6 ${className}`}>
      <div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-between">
        <img src={WOMPI_LOGO} alt="Wompi" class="h-12 w-auto shrink-0 sm:h-14" />
        <div class="text-center sm:text-right">
          <div class="text-base font-bold text-navy">Tus pagos los procesa Wompi</div>
          <div class="mt-1 text-[11px] text-slate-400">
            La pasarela de <span class="font-semibold text-slate-500">Bancolombia</span>. No almacenamos los datos de tu tarjeta.
          </div>
        </div>
      </div>

      <div class="mt-5 flex flex-wrap items-start justify-center gap-x-6 gap-y-4 border-t border-slate-100 pt-5">
        {METHODS.map((m) => (
          <div class="flex w-20 flex-col items-center gap-2">
            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-navy-deep text-white">
              {m.kind === "card" && (
                <svg
                  viewBox="0 0 24 24"
                  class="h-[22px] w-[22px]"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <rect x="2" y="5" width="20" height="14" rx="2.5" />
                  <path d="M2 10h20" />
                </svg>
              )}
              {m.kind === "text" && (
                <span class={`font-extrabold leading-none tracking-tight ${m.size}`}>{m.text}</span>
              )}
              {m.kind === "visa" && (
                <svg viewBox="0 0 24 24" class="w-[26px]" fill="currentColor" aria-hidden="true">
                  <path d={VISA_PATH} />
                </svg>
              )}
              {m.kind === "mastercard" && (
                <svg viewBox="0 0 24 24" class="h-6 w-6" fill="currentColor" aria-hidden="true">
                  <path d={MASTERCARD_PATH} />
                </svg>
              )}
            </div>
            <span class="text-center text-[10px] leading-tight text-slate-500">{m.label}</span>
          </div>
        ))}
      </div>
    </div>
  )
}
