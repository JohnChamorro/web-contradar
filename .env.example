# Resend — usado por la Cloudflare Pages Function functions/api/contact.js
# (en Cloudflare Pages se configuran en Settings > Environment variables)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Destino de las solicitudes de acceso del formulario
CONTACT_TO=hola@contradar.com.co

# Remitente (debe ser un dominio verificado en Resend; en dev usa onboarding@resend.dev)
CONTACT_FROM=ContRadar <onboarding@resend.dev>
